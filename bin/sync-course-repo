#!/bin/bash

usage() {
  echo "Usage: $0 <homework_number_2digits>"
  echo "Options:"
  echo "  -h, --help    Show this help message"
  exit 1
}

while getopts "h" opt; do
  case ${opt} in
    h )
      usage
      ;;
    \? )
      usage
      ;;
  esac
done

if [[ -n "$1" ]]; then
  if [[ ! "$1" =~ ^[0-9]{2}$ ]]; then
    usage
    exit 1
  fi;

  TAR_PARAMS="./homework_$1"
else
  TAR_PARAMS="--exclude='./homework_*' ."
fi;

tmp_dir=$(mktemp -d)

git clone --depth 1 \
  git@github.com:robot-dreams-code/C-PLUS-PLUS-FOR-MILITARY-TECHNOLOGY.git \
  "$tmp_dir/course"

(
  cd "$tmp_dir/course"
  tar -c --exclude='./.git' --exclude='./.gitignore' $TAR_PARAMS -f -
) | tar -xf -

rm -rf "$tmp_dir"

git add .

echo ''
echo 'if changed then applied'
